{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LinkDrive",
  "version": "0.1.0",
  "identifier": "com.moltenpixel.linkdrive",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "beforeBuildCommand": "npm run build:renderer",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1620"
  },
  "app": {
    "windows": [
      {
        "title": "LinkDrive",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "publisher": "MoltenPixelStudio",
    "copyright": "Copyright 2026 MoltenPixelStudio",
    "category": "Utility",
    "shortDescription": "LinkDrive",
    "longDescription": "LinkDrive — fast cross-device file explorer with VPS and LAN peer access.",
    "licenseFile": "../../../LICENSE",
    "windows": {
      "nsis": {
        "template": "templates/installer.nsi",
        "installerIcon": "icons/installer-icon.ico",
        "installMode": "currentUser",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "compression": "lzma",
        "displayLanguageSelector": false,
        "languages": ["English"]
      }
    }
  }
}
