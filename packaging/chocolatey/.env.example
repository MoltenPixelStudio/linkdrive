# Chocolatey publish credentials. Copy to .env and fill in.
# .env is gitignored; never commit real keys.

# API key from https://community.chocolatey.org/account
# Create account first if you don't have one (free).
CHOCO_API_KEY=

# Optional: override the version being packed/pushed (defaults to value
# in linkdrive.nuspec). Useful when shipping a hotfix.
# CHOCO_VERSION=0.2.0
